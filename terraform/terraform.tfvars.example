# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

tenancy_id     = "ocid1.tenancy.oc1..xxxxxxxx"
user_id        = "ocid1.user.oc1..xxxxxxxx"
fingerprint    = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
compartment_id = "ocid1.compartment.oc1..xxxxxxxx" # or the tenancy OCID for the root compartment
github_org     = "CVVFCM"

# Optional overrides:
# private_key_path      = "~/oracle-private.pem"
# region                = "eu-paris-1"
# kubernetes_version    = "v1.31.1"   # empty = latest supported
# node_count            = 2
# node_boot_volume_gb   = 100
# kube_api_ingress_cidr = "0.0.0.0/0"
# http_ingress_cidr     = "0.0.0.0/0" # lock to Cloudflare ranges to force CF proxy
# default_cluster_issuer = "letsencrypt-staging"  # switch to letsencrypt-prod once verified

# Cloudflare DNS (also: export CLOUDFLARE_API_TOKEN=<token>):
# cloudflare_zones = { "cvvfcm.fr" = "3fa2035c4239d02756471c8a0f51f247" }
# domains = [
#   { domain = "meteoprint",  zone = "cvvfcm.fr", proxied = true },
#   { domain = "healthcheck", zone = "cvvfcm.fr", proxied = false }, # cluster HTTP probe
#   { domain = "traefik",     zone = "cvvfcm.fr", proxied = false }, # dashboard (needs traefik_dashboard_users)
#   { domain = "api",         zone = "cvvfcm.fr", proxied = false },
# ]

# Traefik dashboard BasicAuth (also: export TF_VAR_traefik_dashboard_users="$(htpasswd -nbB admin '<pw>')").
# Empty/unset = dashboard not exposed.
# traefik_dashboard_users = "admin:$2y$05$..."

# Grafana Alloy → Grafana Cloud. Endpoints + instance IDs from the Cloud Portal
# stack details; one Access Policy token with metrics/logs/traces write scopes.
# Empty token = Alloy not deployed. Token also: export TF_VAR_grafana_cloud_token=<token>.
# grafana_cloud_prometheus_url  = "https://prometheus-prod-XX-region.grafana.net/api/prom/push"
# grafana_cloud_prometheus_user = "123456"
# grafana_cloud_loki_url        = "https://logs-prod-XX.grafana.net/loki/api/v1/push"
# grafana_cloud_loki_user       = "123456"
# grafana_cloud_token           = "glc_..."

# GitHub org secret export (also: export GITHUB_TOKEN=<PAT with admin:org>):
github_org = "my-org"
# kubeconfig_secret_name = "OKE_KUBECONFIG"

# cert-manager DNS-01 (also: export TF_VAR_cloudflare_dns_api_token=<token>):
# acme_email = "you@example.com"
